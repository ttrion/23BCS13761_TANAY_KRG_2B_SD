        <mxCell id="IG7Cz-LUzywHiOBToCAp-4" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;odd&lt;/font&gt;" vertex="1">
